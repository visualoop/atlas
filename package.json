{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "//": "Local dev ports — proxied via <port>.blyss.co.ke",
    "// 3010": "  - Next.js dev server",
    "// 3220": "  - Convex local backend (API + WebSocket)",
    "// 3221": "  - Convex local backend (HTTP actions site)",
    "// 6791": "  - Convex local dashboard",
    "dev": "convex dev --tail-logs disable --once-and-fail-quickly false & sleep 4 && next dev -p 3010",
    "dev:next": "next dev -p 3010",
    "dev:convex": "convex dev",
    "dev:kill": "for p in 3010 3220 3221 6791; do fuser -k -n tcp $p 2>/dev/null; done; echo Cleared 3010/3220/3221/6791",
    "build": "next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/resend": "^0.1.13",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/js-api-loader": "^2.1.1",
    "@hookform/resolvers": "^3.10.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@react-pdf/renderer": "^4.5.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "convex": "^1.36.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "nanoid": "^5.0.9",
    "next": "16.2.9",
    "next-themes": "^0.4.4",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.9.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
